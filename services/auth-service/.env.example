# Database Configuration
DATABASE_URL=mysql://root:password@localhost:3306/auth_db

# JWT Configuration
# IMPORTANT: Change this secret in production! Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# JWT Token Expiry Settings (Optional - defaults shown)
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Logging (Optional)
RUST_LOG=info

# Service Port (Optional)
SERVICE_PORT=50051
