# Database Configuration
MYSQL_ROOT_PASSWORD=password
AUTH_DB_NAME=auth_db
PRODUCT_DB_NAME=product_db
ORDER_DB_NAME=order_db

# Auth Service Configuration
AUTH_DATABASE_URL=mysql://root:password@auth-db:3306/auth_db
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Product Service Configuration
PRODUCT_DATABASE_URL=mysql://root:password@product-db:3306/product_db

# Order Service Configuration
ORDER_DATABASE_URL=mysql://root:password@order-db:3306/order_db

# Logging
RUST_LOG=info

# Ports
AUTH_SERVICE_PORT=50051
AUTH_DB_PORT=3306
PRODUCT_DB_PORT=3307
ORDER_SERVICE_PORT=50053
ORDER_DB_PORT=3308
